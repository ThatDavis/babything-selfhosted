generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id            String   @id @default(cuid())
  subdomain     String   @unique
  status        String   @default("TRIAL") // TRIAL | ACTIVE | SUSPENDED
  trialEndsAt   DateTime?
  plan          String   @default("FLAT_RATE")
  billingPeriod String   @default("MONTHLY") // MONTHLY | ANNUAL
  referralCode  String?  @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  users    User[]
  babies   Baby[]
  settings SystemSettings?
  monitorAgent MonitorAgent?
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String?
  name          String
  isAdmin       Boolean  @default(false)
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  oauthProvider String?
  oauthId       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  babies              BabyCaregiver[]
  feedings            FeedingEvent[]
  diapers             DiaperEvent[]
  sleepEvents         SleepEvent[]
  growthRecords       GrowthRecord[]
  medications         MedicationEvent[]
  milestones          Milestone[]
  appointments        Appointment[]
  vaccines            VaccineRecord[]
  invitesSent         InviteToken[]
  passwordResetTokens PasswordResetToken[]

  @@unique([oauthProvider, oauthId])
  @@index([tenantId])
}

model Baby {
  id        String   @id @default(cuid())
  name      String
  dob       DateTime
  sex       String?
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  caregivers    BabyCaregiver[]
  feedings      FeedingEvent[]
  diapers       DiaperEvent[]
  sleepEvents   SleepEvent[]
  growthRecords GrowthRecord[]
  medications   MedicationEvent[]
  milestones    Milestone[]
  appointments  Appointment[]
  vaccines      VaccineRecord[]
  invites       InviteToken[]

  @@index([tenantId])
}

model BabyCaregiver {
  babyId     String
  userId     String
  tenantId   String
  role       Role     @default(CAREGIVER)
  invitedAt  DateTime @default(now())
  acceptedAt DateTime?

  baby Baby @relation(fields: [babyId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([babyId, userId])
  @@index([tenantId])
}

enum Role {
  OWNER
  CAREGIVER
}

model InviteToken {
  token     String    @id
  babyId    String
  email     String
  role      Role      @default(CAREGIVER)
  createdBy String
  tenantId  String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  baby    Baby @relation(fields: [babyId], references: [id], onDelete: Cascade)
  creator User @relation(fields: [createdBy], references: [id])

  @@index([tenantId])
}

model FeedingEvent {
  id          String    @id @default(cuid())
  babyId      String
  loggedBy    String
  tenantId    String
  type        FeedType
  side        String?
  durationMin Int?
  amount      Float?
  milkType    String?
  startedAt   DateTime
  endedAt     DateTime?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  baby Baby @relation(fields: [babyId], references: [id], onDelete: Cascade)
  user User @relation(fields: [loggedBy], references: [id])

  @@index([tenantId])
}

enum FeedType {
  BREAST
  BOTTLE
}

model DiaperEvent {
  id         String     @id @default(cuid())
  babyId     String
  loggedBy   String
  tenantId   String
  type       DiaperType
  color      String?
  occurredAt DateTime
  notes      String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  baby Baby @relation(fields: [babyId], references: [id], onDelete: Cascade)
  user User @relation(fields: [loggedBy], references: [id])

  @@index([tenantId])
}

enum DiaperType {
  WET
  DIRTY
  BOTH
  DRY
}

model SleepEvent {
  id        String     @id @default(cuid())
  babyId    String
  loggedBy  String
  tenantId  String
  type      SleepType
  location  String?
  startedAt DateTime
  endedAt   DateTime?
  notes     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  baby Baby @relation(fields: [babyId], references: [id], onDelete: Cascade)
  user User @relation(fields: [loggedBy], references: [id])

  @@index([tenantId])
}

enum SleepType {
  NAP
  NIGHT
}

model GrowthRecord {
  id         String   @id @default(cuid())
  babyId     String
  loggedBy   String
  tenantId   String
  weight     Float?
  length     Float?
  headCirc   Float?
  measuredAt DateTime
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  baby Baby @relation(fields: [babyId], references: [id], onDelete: Cascade)
  user User @relation(fields: [loggedBy], references: [id])

  @@index([tenantId])
}

model MedicationEvent {
  id         String   @id @default(cuid())
  babyId     String
  loggedBy   String
  tenantId   String
  name       String
  dose       Float
  unit       String
  occurredAt DateTime
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  baby Baby @relation(fields: [babyId], references: [id], onDelete: Cascade)
  user User @relation(fields: [loggedBy], references: [id])

  @@index([tenantId])
}

model Milestone {
  id          String   @id @default(cuid())
  babyId      String
  loggedBy    String
  tenantId    String
  title       String
  description String?
  occurredAt  DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  baby Baby @relation(fields: [babyId], references: [id], onDelete: Cascade)
  user User @relation(fields: [loggedBy], references: [id])

  @@index([tenantId])
}

model Appointment {
  id        String          @id @default(cuid())
  babyId    String
  loggedBy  String
  tenantId  String
  date      DateTime
  doctor    String?
  type      AppointmentType @default(WELL_VISIT)
  notes     String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  baby     Baby            @relation(fields: [babyId], references: [id], onDelete: Cascade)
  user     User            @relation(fields: [loggedBy], references: [id])
  vaccines VaccineRecord[]

  @@index([tenantId])
}

enum AppointmentType {
  WELL_VISIT
  SICK_VISIT
  SPECIALIST
  OTHER
}

model VaccineRecord {
  id             String   @id @default(cuid())
  babyId         String
  loggedBy       String
  tenantId       String
  vaccineName    String
  doseNumber     Int?
  lotNumber      String?
  administeredAt DateTime
  appointmentId  String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  baby        Baby         @relation(fields: [babyId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [loggedBy], references: [id])
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([tenantId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  tenantId  String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model OAuthProvider {
  id               String   @id @default(cuid())
  name             String   @unique
  label            String
  clientId         String
  clientSecret     String
  authorizationUrl String
  tokenUrl         String
  userInfoUrl      String
  scope            String   @default("openid email profile")
  enabled          Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model SmtpConfig {
  id        String   @id @default(cuid())
  host      String
  port      Int      @default(587)
  secure    Boolean  @default(false)
  user      String
  password  String
  fromEmail String
  fromName  String   @default("Babything")
  enabled   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Referral {
  id                String    @id @default(cuid())
  referrerSubdomain String
  refereeSubdomain  String    @unique
  code              String
  status            String    @default("PENDING") // PENDING | REWARDED
  createdAt         DateTime  @default(now())
  rewardAppliedAt   DateTime?

  @@index([referrerSubdomain])
  @@index([code])
}

model DiscountCode {
  id         String    @id @default(cuid())
  code       String    @unique
  type       String    // FREE_TIME | PERCENTAGE
  value      Int       // days for FREE_TIME, percent for PERCENTAGE
  maxUses    Int?
  usedCount  Int       @default(0)
  validFrom  DateTime  @default(now())
  validUntil DateTime?
  appliesTo  String    @default("ANY") // ANY | ANNUAL | MONTHLY
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model SystemSettings {
  tenantId      String   @id
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  unitSystem    String   @default("metric")
  streamEnabled Boolean  @default(false)
  updatedAt     DateTime @updatedAt
}

enum OperatorRole {
  HELPDESK
  ACCOUNTING
  GLOBAL_ADMIN
}

model Operator {
  id           String       @id @default(cuid())
  email        String       @unique
  name         String
  passwordHash String
  role         OperatorRole @default(HELPDESK)
  isActive     Boolean      @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  auditLogs AuditLog[]
}

model AuditLog {
  id         String   @id @default(cuid())
  operatorId String
  operator   Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  action     String   // e.g. "suspend_tenant", "extend_trial", "login", "create_operator"
  targetType String?  // e.g. "tenant", "operator"
  targetId   String?  // the ID of the target entity
  oldValue   String?  // JSON string of previous state
  newValue   String?  // JSON string of new state
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([operatorId])
  @@index([targetType, targetId])
  @@index([createdAt])
}

model EmailTemplate {
  id        String   @id @default(cuid())
  name      String   @unique // e.g. "welcome", "invite", "password_reset", "report"
  subject   String
  htmlBody  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Plan {
  id                   String   @id @default(cuid())
  name                 String   @unique
  description          String?
  monthlyPrice         Int      // price in cents
  annualPrice          Int      // price in cents
  stripeMonthlyPriceId String?
  stripeAnnualPriceId  String?
  annualDiscountPercent Int?    // e.g. 20 means 20% off annual vs monthly*12
  features             String[] @default([])
  isActive             Boolean  @default(true)
  sortOrder            Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model MonitorAgent {
  id          String   @id @default(cuid())
  tenantId    String   @unique
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessionId   String   @unique
  connectedAt DateTime @default(now())
  lastPingAt  DateTime @updatedAt
  status      String   @default("CONNECTED") // CONNECTED | DISCONNECTED

  @@index([tenantId])
}
