PORT=3002
DATABASE_URL=file:./provisioning.db

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
STRIPE_ANNUAL_PRICE_ID=
# Set to true to skip Stripe calls during signup (dev/testing only)
STRIPE_BYPASS=

MAIN_APP_URL=http://api:3001
INTERNAL_API_KEY=dev-internal-secret-min-32-chars-long

# mTLS (cloud mode only — replaces INTERNAL_API_KEY for service-to-service auth)
# Run ./scripts/generate-mtls-certs before deploying.
# MTLS_ENABLED=false
# TLS_CERT_PATH=/certs/provisioning-client.crt
# TLS_KEY_PATH=/certs/provisioning-client.key
# TLS_CA_PATH=/certs/ca.crt
