DEPLOYMENT_MODE=selfhosted
DATABASE_URL=postgresql://babything:changeme@localhost:5432/babything
INTERNAL_API_KEY=dev-internal-secret-min-32-chars-long
JWT_SECRET=dev-secret-change-me-min-32-chars-long

# Redis
REDIS_URL=redis://localhost:6379

# Stripe (provisioning service)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
INVITE_SECRET=dev-invite-secret-min-32-chars-long
ENCRYPTION_KEY=
APP_URL=http://localhost
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# mTLS (cloud mode only — set automatically via docker-compose.cloud.yml)
# MTLS_ENABLED=false
# MTLS_PORT=3003
# TLS_CERT_PATH=/certs/api-server.crt
# TLS_KEY_PATH=/certs/api-server.key
# TLS_CA_PATH=/certs/ca.crt
