POSTGRES_USER=babything
POSTGRES_PASSWORD=changeme
POSTGRES_DB=babything

# Image tag for cloud deployments (latest, v1.2.3, or short SHA)
IMAGE_TAG=latest

# Root domain for subdomain routing
ROOT_DOMAIN=example.com

INTERNAL_API_KEY=change-this-to-a-long-random-secret-for-internal-api
JWT_SECRET=change-this-to-a-long-random-string

# Redis
REDIS_PASSWORD=changeme

# Stripe (provisioning service)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...
STRIPE_ANNUAL_PRICE_ID=price_...
# Set to true to skip Stripe calls during signup (dev/testing only)
# STRIPE_BYPASS=true
INVITE_SECRET=change-this-too

# Public URL used for OAuth redirects and email links (no trailing slash)
APP_URL=https://example.com

# Cloud email: Resend API (preferred)
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=re_...
FROM_EMAIL=hello@example.com
FROM_NAME=Babything

# Fallback SMTP (when Resend is not configured)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=...
# SMTP_PASS=...
# SMTP_FROM_EMAIL=hello@example.com
# SMTP_FROM_NAME=Babything

# Encryption key for sensitive data at rest
# Must be set in production. Generate with: openssl rand -base64 32
ENCRYPTION_KEY=

# Google OAuth (recommended for cloud)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Host port for nginx
PORT=80

# Reverse proxy trust (comma-separated IPs or CIDR ranges)
# Required when running behind nginx, Caddy, a cloud load balancer, etc.
TRUSTED_PROXIES=127.0.0.1,10.0.0.0/8

# Cookie domain for cloud mode (defaults to .ROOT_DOMAIN)
# COOKIE_DOMAIN=.example.com

# TLS notes:
# For HTTPS, put this stack behind an external reverse proxy (nginx, Caddy,
# Cloudflare, etc.) that terminates TLS and forwards plain HTTP.
# Do NOT enable HSTS until you are sure HTTPS works, or you will lock yourself out.

# mTLS (internal service-to-service communication)
# Run ./scripts/generate-mtls-certs before deploying the cloud stack.
# These variables are set automatically in docker-compose.cloud.yml via volume mounts.
# MTLS_ENABLED=false
# TLS_CERT_PATH=/certs/server.crt
# TLS_KEY_PATH=/certs/server.key
# TLS_CA_PATH=/certs/ca.crt

# TURN server (for WebRTC monitor relay when P2P fails)
# Set these to enable the coturn container in docker-compose.cloud.yml.
# TURN_URL=turn:your-server-ip:3478
# TURN_USERNAME=babything
# TURN_CREDENTIAL=change-me-in-production
# EXTERNAL_IP=your-server-public-ip

# Landing page links (optional)
# VITE_GITHUB_REPO_URL=https://github.com/ThatDavis/babything-selfhosted
# VITE_DONATION_URL=https://github.com/sponsors/ThatDavis
