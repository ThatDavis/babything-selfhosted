FROM node:20-alpine AS builder
WORKDIR /app
COPY package.json package-lock.json* ./
RUN npm ci
COPY . .

ARG VITE_API_URL
ARG VITE_AFFILIATE_SCRIPT_URL
ARG VITE_AFFILIATE_SIGNUP_URL
ARG VITE_GITHUB_REPO_URL
ARG VITE_DONATION_URL
ENV VITE_API_URL=${VITE_API_URL}
ENV VITE_AFFILIATE_SCRIPT_URL=${VITE_AFFILIATE_SCRIPT_URL}
ENV VITE_AFFILIATE_SIGNUP_URL=${VITE_AFFILIATE_SIGNUP_URL}
ENV VITE_GITHUB_REPO_URL=${VITE_GITHUB_REPO_URL}
ENV VITE_DONATION_URL=${VITE_DONATION_URL}

RUN npm run build

FROM nginx:alpine
COPY --from=builder /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
