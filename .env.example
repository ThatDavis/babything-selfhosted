POSTGRES_USER=babything
POSTGRES_PASSWORD=changeme
POSTGRES_DB=babything

INTERNAL_API_KEY=change-this-to-a-long-random-secret-for-internal-api
JWT_SECRET=change-this-to-a-long-random-string
INVITE_SECRET=change-this-too

# Redis
REDIS_PASSWORD=changeme

# Public URL used for OAuth redirects and email links (no trailing slash)
APP_URL=http://localhost

# SMTP (optional — can also be configured via Admin Settings UI)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=...
# SMTP_PASS=...
# SMTP_FROM_EMAIL=hello@babything.app
# SMTP_FROM_NAME=Babything

# Encryption key for sensitive data at rest (SMTP passwords, OAuth secrets)
# Must be set in production. Generate with: openssl rand -base64 32
ENCRYPTION_KEY=

# Google OAuth (optional — enables "Sign in with Google")
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Host port for nginx
PORT=80

# Baby monitor — RTSP URL of your camera (leave blank to disable)
CAMERA_RTSP_URL=

# Reverse proxy trust (comma-separated IPs or CIDR ranges).
# Required when running behind nginx, Caddy, a cloud load balancer, etc.
# TRUSTED_PROXIES=

# TLS notes:
# For HTTPS, put this stack behind an external reverse proxy (nginx, Caddy,
# Cloudflare, etc.) that terminates TLS and forwards plain HTTP.
# Alternatively, uncomment the TLS section in nginx/nginx.conf and mount
# certificates directly on the nginx container.
# Do NOT enable HSTS until you are sure HTTPS works, or you will lock yourself out.
