POSTGRES_USER=babything
POSTGRES_PASSWORD=changeme
POSTGRES_DB=babything

DEPLOYMENT_MODE=selfhosted   # or "cloud"
INTERNAL_API_KEY=change-this-to-a-long-random-secret-for-internal-api
JWT_SECRET=change-this-to-a-long-random-string

# Redis
REDIS_PASSWORD=changeme

# Stripe (provisioning service)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...
STRIPE_ANNUAL_PRICE_ID=price_...
INVITE_SECRET=change-this-too

# Public URL used for OAuth redirects and email links (no trailing slash)
APP_URL=http://localhost

# Encryption key for sensitive data at rest (SMTP password, OAuth secrets)
# Must be set in production. Generate with: openssl rand -base64 32
ENCRYPTION_KEY=

# Google OAuth (optional — enables "Sign in with Google")
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Host port for Nginx
PORT=80

# Reverse proxy trust (comma-separated IPs). Only set this when behind nginx/traefik.
# TRUSTED_PROXIES=127.0.0.1

# TLS notes:
# For HTTPS, put this stack behind a reverse proxy (Traefik, Caddy, cloudflare, etc.)
# or uncomment the TLS section in nginx/nginx.conf and mount certificates.
# Do NOT enable HSTS until you are sure HTTPS works, or you will lock yourself out.

# mTLS (cloud mode only)
# Run ./scripts/generate-mtls-certs before deploying the cloud stack.
# These variables are set automatically in docker-compose.cloud.yml via volume mounts.
# MTLS_ENABLED=false
# TLS_CERT_PATH=/certs/server.crt
# TLS_KEY_PATH=/certs/server.key
# TLS_CA_PATH=/certs/ca.crt

# Affiliate program (optional — loads tracking script on landing page)
# Set to your Rewardful/Tolt script URL and affiliate signup page.
# VITE_AFFILIATE_SCRIPT_URL=https://rwdl.net/...
# VITE_AFFILIATE_SIGNUP_URL=https://babything.getrewardful.com/...
