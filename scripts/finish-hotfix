#!/usr/bin/env bash
set -euo pipefail

# finish-hotfix — Merge a hotfix branch into main (regular merge, not squash)
#
# Usage: ./scripts/finish-hotfix
# Must be run from a hotfix branch.

CURRENT_BRANCH=$(git branch --show-current)

if [ "$CURRENT_BRANCH" = "main" ]; then
  echo "❌ You are on main. Run this from a hotfix branch."
  exit 1
fi

if [[ ! "$CURRENT_BRANCH" =~ ^hotfix/ ]]; then
  echo "⚠️  '$CURRENT_BRANCH' does not look like a hotfix branch."
  read -p "Continue anyway? [y/N] " -n 1 -r
  echo
  if [[ ! $REPLY =~ ^[Yy]$ ]]; then
    exit 1
  fi
fi

if ! git diff-index --quiet HEAD --; then
  echo "❌ Uncommitted changes. Commit or stash first."
  exit 1
fi

BRANCH="$CURRENT_BRANCH"

echo "📋 Commits on $BRANCH:"
git log --oneline main.."$BRANCH"
echo ""

read -p "Merge '$BRANCH' into main with a regular merge commit? [y/N] " -n 1 -r
echo
if [[ ! $REPLY =~ ^[Yy]$ ]]; then
  exit 1
fi

git checkout main
git pull origin main

echo "🔀 Merging $BRANCH into main..."
git merge --no-ff "$BRANCH" -m "hotfix: merge $BRANCH"

echo ""
git log --oneline -3

read -p "Push main? [Y/n] " -n 1 -r
echo
if [[ ! $REPLY =~ ^[Nn]$ ]]; then
  git push origin main
fi

read -p "Delete local branch '$BRANCH'? [Y/n] " -n 1 -r
echo
if [[ ! $REPLY =~ ^[Nn]$ ]]; then
  git branch -D "$BRANCH"
fi

echo "✅ Hotfix deployed."
